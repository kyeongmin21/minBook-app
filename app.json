{
    "expo": {
        "name": "book-app",
        "slug": "book-app",
        "owner": "minmeanduck",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/logo.png",
        "scheme": "bookapp",
        "userInterfaceStyle": "light",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#E6F4FE",
                "foregroundImage": "./assets/images/android-icon-foreground.png",
                "backgroundImage": "./assets/images/android-icon-background.png",
                "monochromeImage": "./assets/images/android-icon-monochrome.png"
            },
            "edgeToEdgeEnabled": true,
            "predictiveBackGestureEnabled": false
        },
        "web": {
            "output": "static",
            "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "image": "./assets/images/splash-icon.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#ffffff",
                    "dark": {
                        "backgroundColor": "#000000"
                    }
                }
            ],
            "@react-native-community/datetimepicker"
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "9b729677-3084-4214-8309-e6ab370da2a3"
            },
            "supabaseUrl": "https://zppdjwxceeddpeukwvvv.supabase.co",
            "supabaseAnonKey": "sb_publishable_RO-T42v_jSEOzr9s9LLt-A_8eUCviNi",
            "kakaoRestApiKey": "0ac8845c91a68f8d47aa54ea1fb40611"
        }
    }
}
